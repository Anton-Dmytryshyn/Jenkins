pipeline {
    agent any  // Use any available agent

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'stage', 'demo', 'prod'], description: 'Select environment to deploy')
    }

    stages {

        stage('Stage 1 - When Demo') {
            when {
                expression { params.ENVIRONMENT == 'demo' } // Only run if demo is selected
            }
            steps {
                echo "Deployment on ${params.ENVIRONMENT}" // Print environment
            }
        }

        stage('Stage 2 - Script Condition') {
            steps {
                script {
                    if (params.ENVIRONMENT == 'prod') { // Conditional logic inside script
                        echo "Deployment on ${params.ENVIRONMENT}" 
                    } else {
                        echo "Skipping deployment on ${params.ENVIRONMENT}" 
                    }
                }
            }
        }

    }

    post {
        always {
            echo "Pipeline finished"
        }
    }
}
